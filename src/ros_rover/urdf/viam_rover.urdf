<?xml version="1.0"?>
<robot name="viam_rover">

  <!-- Materials -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <!-- Base Link (Projection on the ground between the drive wheels) -->
  <link name="base_link"/>

  <!-- Chassis -->
  <link name="chassis">
    <visual>
      <!-- Viam Rover 1 is approx 31cm long, 21cm wide, 7cm tall -->
      <geometry>
        <box size="0.31 0.21 0.07"/>
      </geometry>
      <material name="blue"/>
      <!-- Offset so the bottom of the chassis sits at the joint origin -->
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="base_link_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <!-- Center of the drive wheels is the base_link. 
         Drive wheels are at the front. We offset the chassis 
         back so the wheels stay at the front of the body. -->
    <origin xyz="-0.08 0 0.02"/>
  </joint>

  <!-- Left Wheel (Front Left) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <!-- Rotate the cylinder visual to lie on its side (Y-axis) -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Position relative to base_link (front-center of wheels) -->
    <origin xyz="0 0.12 0.0125" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right Wheel (Front Right) -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0 -0.12 0.0125" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster Wheel (Back) -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel"/>
    <!-- Positioned at the rear of the 31cm chassis -->
    <origin xyz="-0.14 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Laser Frame (Lidar) -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black"/>
      <!-- Sit bottom of cylinder on joint -->
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="chassis"/>
    <child link="laser_frame"/>
    <!-- Centered on top of the chassis box -->
    <origin xyz="0.05 0 0.07" rpy="0 0 0"/>
  </joint>

</robot>
