<?xml version="1.0"?>
<robot name="viam_rover">

  <!-- Materials -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <!-- Base Link (Global Origin / Rotation Center) -->
  <link name="base_link"/>

  <!-- Chassis -->
  <link name="chassis">
    <visual>
      <!-- Viam Rover 1 is approx 31cm long, 21cm wide, 7cm tall -->
      <geometry>
        <box size="0.31 0.21 0.07"/>
      </geometry>
      <material name="blue"/>
      <!-- The joint is at the bottom center of the box, shift visual up by half-height -->
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="base_link_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <!-- Elevate chassis 1.5cm off the ground to match the 1.5cm caster radius.
         Centered on the base_link for better stability. -->
    <origin xyz="0 0 0.015"/>
  </joint>

  <!-- Left Wheel (Front Left) -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <!-- Cylinder is Z-up by default. Rotate PI/2 (1.5708) around X to align with Y-axis -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- X=0.10 (Front), Y=0.13 (Outside the 21cm chassis), Z=0.0325 (Radius height) 
         Center of wheel is at 3.25cm, so bottom is at 0 (Ground Contact) -->
    <origin xyz="0.10 0.13 0.0325" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Right Wheel (Front Right) -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="0.10 -0.13 0.0325" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Caster Wheel (Rear Stability) -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel"/>
    <!-- Positioned at the rear of the chassis (X = -0.12). 
         Since chassis is at Z=0.015, this 1.5cm sphere sits perfectly on Z=0. -->
    <origin xyz="-0.12 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Laser Frame (Lidar) -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="chassis"/>
    <child link="laser_frame"/>
    <!-- Mounted on top of the 7cm chassis, towards the front -->
    <origin xyz="0.08 0 0.07" rpy="0 0 0"/>
  </joint>

</robot>
