<?xml version="1.0"?>
<robot name="viam_rover">

  <!-- Materials -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <!-- Base Link (Ground Projection) -->
  <link name="base_link"/>

  <!-- Chassis -->
  <link name="chassis">
    <visual>
      <geometry>
        <box size="0.2 0.15 0.07"/>
      </geometry>
      <material name="blue"/>
      <!-- Center the box visual so the bottom is at Z=0 relative to its joint -->
      <origin xyz="0 0 0.035" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="base_link_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <!-- Raise chassis 1.5cm off the ground for clearance -->
    <origin xyz="0 0 0.015"/>
  </joint>

  <!-- Left Wheel -->
  <link name="left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <!-- URDF Cylinders are centered on their origin; no offset needed if joint is correct -->
    </visual>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <!-- Moved Y to 0.10 (10cm) so it clears the 15cm wide chassis -->
    <origin xyz="0 0.10 0.0325" rpy="-1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Right Wheel -->
  <link name="right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
    </visual>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <!-- Moved Y to -0.10 (10cm) -->
    <origin xyz="0 -0.10 0.0325" rpy="1.5708 0 0"/>
    <axis xyz="0 0 1"/>
  </joint>

  <!-- Caster Wheel (The White Piece) -->
  <!-- This is a non-powered sliding wheel at the front for stability -->
  <link name="caster_wheel">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="chassis"/>
    <child link="caster_wheel"/>
    <!-- Place at the front (+0.08) and bottom (0.0) of the chassis -->
    <!-- Since chassis is 1.5cm up, a 1.5cm sphere sits perfectly on the ground -->
    <origin xyz="0.08 0 0" rpy="0 0 0"/>
  </joint>

  <!-- Laser Frame (Lidar) -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="chassis"/>
    <child link="laser_frame"/>
    <!-- Sits exactly on top of the 7cm tall chassis -->
    <origin xyz="0.05 0 0.07" rpy="0 0 0"/>
  </joint>

</robot>
