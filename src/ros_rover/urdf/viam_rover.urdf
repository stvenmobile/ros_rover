<?xml version="1.0"?>
<robot name="viam_rover">

  <!-- Materials -->
  <material name="blue">
    <color rgba="0 0 0.8 1"/>
  </material>
  <material name="black">
    <color rgba="0 0 0 1"/>
  </material>
  <material name="white">
    <color rgba="1 1 1 1"/>
  </material>

  <!-- Base Link (Global Origin / Ground Level Center) -->
  <link name="base_link"/>

  <!-- Chassis -->
  <link name="chassis">
    <visual>
      <!-- Viam Rover 1: 31cm L, 21cm W, 7cm H -->
      <geometry>
        <box size="0.31 0.21 0.07"/>
      </geometry>
      <material name="blue"/>
      <!-- Visual origin is 0,0,0 relative to the centered joint -->
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="base_link_to_chassis" type="fixed">
    <parent link="base_link"/>
    <child link="chassis"/>
    <!-- Center of the 7cm box is at Z = 1.5cm (clearance) + 3.5cm (half-height) = 5cm -->
    <origin xyz="0 0 0.05"/>
  </joint>

  <!-- Front Left Wheel -->
  <link name="front_left_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <!-- Rotate cylinder to sit on its side along the Y axis -->
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="front_left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_left_wheel"/>
    <!-- Forward 12cm, Left 13cm, Axle at 3.25cm (so bottom touches Z=0) -->
    <origin xyz="0.12 0.13 0.0325" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Front Right Wheel -->
  <link name="front_right_wheel">
    <visual>
      <geometry>
        <cylinder length="0.025" radius="0.0325"/>
      </geometry>
      <material name="black"/>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
    </visual>
  </link>

  <joint name="front_right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="front_right_wheel"/>
    <!-- Forward 12cm, Right 13cm, Axle at 3.25cm -->
    <origin xyz="0.12 -0.13 0.0325" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- Rear Caster Wheel -->
  <link name="rear_caster">
    <visual>
      <geometry>
        <sphere radius="0.015"/>
      </geometry>
      <material name="white"/>
    </visual>
  </link>

  <joint name="rear_caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="rear_caster"/>
    <!-- Back 12cm, Centered, Height 1.5cm (so bottom touches Z=0) -->
    <origin xyz="-0.12 0 0.015" rpy="0 0 0"/>
  </joint>

  <!-- Laser Frame (Lidar) -->
  <link name="laser_frame">
    <visual>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
      <material name="black"/>
      <!-- Bottom of sensor sits on joint -->
      <origin xyz="0 0 0.02" rpy="0 0 0"/>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="chassis"/>
    <child link="laser_frame"/>
    <!-- Mounted on top of the chassis (3.5cm above chassis center) -->
    <origin xyz="0.08 0 0.035" rpy="0 0 0"/>
  </joint>

</robot>
